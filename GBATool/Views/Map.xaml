									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="7" PaletteIndex="7" Padding="5,0,0,5" x:Name="palette7" Grid.Column="2"/>
								<Label Content="8" Grid.Column="0" Grid.Row="8" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="8"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[8].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
									<i:Interaction.Behaviors>
										<behaviors:EventToCommandBehavior Command="{Binding FileModelVOSelectionChangedCommand}" Event="SelectionChanged" PassArguments="True" />
									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="8" PaletteIndex="8" Padding="5,0,0,5" x:Name="palette8" Grid.Column="2"/>
								<Label Content="9" Grid.Column="0" Grid.Row="9" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="9"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[9].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
									<i:Interaction.Behaviors>
										<behaviors:EventToCommandBehavior Command="{Binding FileModelVOSelectionChangedCommand}" Event="SelectionChanged" PassArguments="True" />
									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="9" PaletteIndex="9" Padding="5,0,0,5" x:Name="palette9" Grid.Column="2"/>
								<Label Content="10" Grid.Column="0" Grid.Row="10" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="10"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[10].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
									<i:Interaction.Behaviors>
										<behaviors:EventToCommandBehavior Command="{Binding FileModelVOSelectionChangedCommand}" Event="SelectionChanged" PassArguments="True" />
									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="10" PaletteIndex="10" Padding="5,0,0,5" x:Name="palette10" Grid.Column="2"/>
								<Label Content="11" Grid.Column="0" Grid.Row="11" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="11"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[11].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
