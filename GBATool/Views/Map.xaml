										<behaviors:EventToCommandBehavior Command="{Binding FileModelVOSelectionChangedCommand}" Event="SelectionChanged" PassArguments="True" />
									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="3" PaletteIndex="3" Padding="5,0,0,5" x:Name="palette3" Grid.Column="2"/>
								<Label Content="4" Grid.Column="0" Grid.Row="4" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="4"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[4].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
									<i:Interaction.Behaviors>
										<behaviors:EventToCommandBehavior Command="{Binding FileModelVOSelectionChangedCommand}" Event="SelectionChanged" PassArguments="True" />
									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="4" PaletteIndex="4" Padding="5,0,0,5" x:Name="palette4" Grid.Column="2"/>
								<Label Content="5" Grid.Column="0" Grid.Row="5" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="5"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[5].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
									<i:Interaction.Behaviors>
										<behaviors:EventToCommandBehavior Command="{Binding FileModelVOSelectionChangedCommand}" Event="SelectionChanged" PassArguments="True" />
									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="5" PaletteIndex="5" Padding="5,0,0,5" x:Name="palette5" Grid.Column="2"/>
								<Label Content="6" Grid.Column="0" Grid.Row="6" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="6"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[6].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
