									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="13" PaletteIndex="13" Padding="5,0,0,5" x:Name="palette13" Grid.Column="2"/>
								<Label Content="14" Grid.Column="0" Grid.Row="14" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="14"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[14].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
