										<behaviors:EventToCommandBehavior Command="{Binding FileModelVOSelectionChangedCommand}" Event="SelectionChanged" PassArguments="True" />
									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="14" PaletteIndex="14" Padding="5,0,0,5" x:Name="palette14" Grid.Column="2"/>
								<Label Content="15" Grid.Column="0" Grid.Row="15" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="15"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[15].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
