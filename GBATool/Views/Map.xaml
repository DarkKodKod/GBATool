								<ComboBox Width="150" Grid.Row="13"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[13].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
