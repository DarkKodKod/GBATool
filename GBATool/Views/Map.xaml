									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="2" PaletteIndex="2" Padding="5,0,0,5" x:Name="palette2" Grid.Column="2"/>
								<Label Content="3" Grid.Column="0" Grid.Row="3" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="3"
                                          Margin="1"
										  Grid.Column="1"
