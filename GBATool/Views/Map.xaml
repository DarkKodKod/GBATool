<UserControl x:Class="GBATool.Views.Map"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GBATool.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:GBATool.Utils.Behaviors"
             xmlns:fx="clr-namespace:ArchitectureLibrary.FXs;assembly=ArchitectureLibrary"
             xmlns:uc="clr-namespace:GBATool.Views"
             xmlns:vm="clr-namespace:GBATool.ViewModels"
             xmlns:cv="clr-namespace:ArchitectureLibrary.WPF.Converters;assembly=ArchitectureLibrary"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             Name="MapView"
             Loaded="MapView_Loaded"
             Unloaded="MapView_Unloaded"
             mc:Ignorable="d" 
             d:DesignHeight="890" d:DesignWidth="1300">
    <UserControl.DataContext>
        <vm:MapViewModel />
    </UserControl.DataContext>
    <UserControl.Resources>
        <cv:EnumMatchToBooleanConverter x:Key="enumConverter" />
        <cv:WidthConverter x:Key="widthConverter" />
    </UserControl.Resources>
    <Grid Background="LightGray">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="800"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="1">
                <Canvas Width="{Binding CanvasWidth}" 
                        Height="{Binding CanvasHeight}" 
                        x:Name="canvas"
                        Background="DarkGray"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                    <Canvas.RenderTransform>
                        <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}"/>
                    </Canvas.RenderTransform>
                    <Border Visibility="{Binding GridVisibility}"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <VisualBrush TileMode="Tile"
                                         Viewport="0,0,8,8" ViewportUnits="Absolute" 
                                         Viewbox="0,0,8,8" ViewboxUnits="Absolute">
                                <VisualBrush.Visual>
                                    <Rectangle Stroke="Magenta" StrokeThickness="0.1" Height="100" Width="100"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.Background>
                        <Canvas Width="{Binding CanvasWidth}" 
                                Height="{Binding CanvasHeight}" 
                                x:Name="canvasGrid"
                                Background="Transparent">
                        </Canvas>
                    </Border>
                    <Image RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Width="{Binding CanvasWidth}" 
                           Height="{Binding CanvasHeight}" 
                           Source="{Binding MapImage}"
                           Name="imgMap"
                           AllowDrop="True"
                           Stretch="UniformToFill">
                        <i:Interaction.Behaviors>
                            <behaviors:EventToCommandBehavior Command="{Binding DropEventCommand}" Event="Drop" PassArguments="True" />
                            <behaviors:EventToCommandBehavior Command="{Binding DragOverEventCommand}" Event="DragOver" PassArguments="True" />
                            <behaviors:EventToCommandBehavior Command="{Binding DragLeaveEventCommand}" Event="DragLeave" PassArguments="True" />
                            <behaviors:EventToCommandBehavior Command="{Binding MouseMoveEventCommand}" Event="MouseMove" PassArguments="True" />
                            <behaviors:EventToCommandBehavior Command="{Binding MouseDownEventCommand}" Event="MouseDown" PassArguments="True" />
                            <behaviors:EventToCommandBehavior Command="{Binding MouseUpEventCommand}" Event="MouseUp" PassArguments="True" />
                        </i:Interaction.Behaviors>
                    </Image>
                </Canvas>
            </ScrollViewer>
        </Grid>
        <Grid Grid.Column="2">
            <TabControl 
                DockPanel.Dock="Right"
                HorizontalAlignment="Stretch" 
                VerticalAlignment="Stretch">
                <TabItem Header="Configuration">
                </TabItem>
				<TabItem Header="Bank">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="10"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="10"/>
						</Grid.ColumnDefinitions>
						<Grid Grid.Column="1">
							<Grid.RowDefinitions>
								<RowDefinition Height="5"/>
								<RowDefinition Height="auto"/>
								<RowDefinition Height="5"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>
							<StackPanel Orientation="Horizontal" Grid.Row="1">
								<ComboBox Width="200"
                                          ItemsSource="{Binding Banks}" 
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding Path=SelectedBank, Mode=TwoWay}">
									<i:Interaction.Behaviors>
										<behaviors:EventToCommandBehavior Command="{Binding FileModelVOSelectionChangedCommand}" Event="SelectionChanged" PassArguments="True" />
									</i:Interaction.Behaviors>
								</ComboBox>
							</StackPanel>
							<ScrollViewer
								VerticalAlignment="Top"
                                Grid.Row="3"
                                PanningMode="Both"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Visible" >
								<local:BankViewerView 
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    AllowDrop="True"
                                    Force2DView="True"
                                    x:Name="bankViewer"/>
							</ScrollViewer>
						</Grid>
					</Grid>
				</TabItem>
				<TabItem Header="Tiles" IsSelected="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
							<RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                        </Grid.ColumnDefinitions>
					    <GroupBox Header="Palettes" Grid.Row="0" Grid.Column="1">
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
									<RowDefinition Height="auto"/>
								</Grid.RowDefinitions>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="22"/>
									<ColumnDefinition Width="auto"/>
									<ColumnDefinition Width="300"/>
								</Grid.ColumnDefinitions>
								<Label Content="0" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="0"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[0].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
									<i:Interaction.Behaviors>
										<behaviors:EventToCommandBehavior Command="{Binding FileModelVOSelectionChangedCommand}" Event="SelectionChanged" PassArguments="True" />
									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="0" PaletteIndex="0" Padding="5,0,0,5" x:Name="palette0" Grid.Column="2"/>
								<Label Content="1" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="1"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[1].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
									<i:Interaction.Behaviors>
										<behaviors:EventToCommandBehavior Command="{Binding FileModelVOSelectionChangedCommand}" Event="SelectionChanged" PassArguments="True" />
									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="1" PaletteIndex="1" Padding="5,0,0,5" x:Name="palette1" Grid.Column="2"/>
								<Label Content="2" Grid.Column="0" Grid.Row="2" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="2"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
