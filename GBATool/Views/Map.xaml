								</ComboBox>
								<local:PaletteViewer Grid.Row="15" PaletteIndex="15" Padding="5,0,0,5" x:Name="palette15" Grid.Column="2"/>
							</Grid>
						</GroupBox>
						<GroupBox Header="Tile" Grid.Row="1" Grid.Column="1">

						</GroupBox>
					</Grid>
                </TabItem>
                <TabItem Header="Entities">
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
