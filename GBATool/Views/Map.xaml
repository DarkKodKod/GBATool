									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="6" PaletteIndex="6" Padding="5,0,0,5" x:Name="palette6" Grid.Column="2"/>
								<Label Content="7" Grid.Column="0" Grid.Row="7" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="7"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[7].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
									<i:Interaction.Behaviors>
