									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="11" PaletteIndex="11" Padding="5,0,0,5" x:Name="palette11" Grid.Column="2"/>
								<Label Content="12" Grid.Column="0" Grid.Row="12" HorizontalAlignment="Center"/>
								<ComboBox Width="150" Grid.Row="12"
                                          Margin="1"
										  Grid.Column="1"
                                          ItemsSource="{Binding Palettes}" 
                                          DisplayMemberPath="FullName"
                                          SelectedValuePath="Index"
                                          SelectedValue="{Binding PaletteIDs[12].Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
									<i:Interaction.Behaviors>
										<behaviors:EventToCommandBehavior Command="{Binding FileModelVOSelectionChangedCommand}" Event="SelectionChanged" PassArguments="True" />
									</i:Interaction.Behaviors>
								</ComboBox>
								<local:PaletteViewer Grid.Row="12" PaletteIndex="12" Padding="5,0,0,5" x:Name="palette12" Grid.Column="2"/>
